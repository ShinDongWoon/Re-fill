          .minimized .rk-compose { display:none; }
          .minimized { height: auto; }
        </style>

        <div class="rk-root" id="rk-root">
          <div class="rk-header">
            <div class="rk-title">Keynes</div>
            <div class="rk-controls">
              <button class="rk-btn" id="rk-btn-key" title="API Key 설정">🔑</button>
              <button class="rk-btn" id="rk-btn-refresh" title="본문 재추출">↻</button>
              <button class="rk-btn" id="rk-btn-dock" title="도킹/플로팅 전환">📌</button>
              <button class="rk-btn" id="rk-btn-clear" title="대화 초기화">🧹</button>
              <button class="rk-btn" id="rk-btn-min" title="최소화">—</button>
            </div>
          </div>
          <div class="rk-status" id="rk-status"></div>
          <div class="rk-messages" id="rk-messages"></div>
          <div class="rk-compose">
            <textarea id="rk-input" placeholder="기사에 대해 질문하기... (Enter=전송, Shift+Enter=줄바꿈)"></textarea>
