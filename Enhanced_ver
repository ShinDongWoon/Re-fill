            border-bottom: 1px solid rgba(0,0,0,.12);
          }
          .rk-title { font-weight: 700; font-size: 14px; letter-spacing: .2px; }
          .rk-controls { display:flex; gap:6px; align-items:center; }
          .rk-btn {
            font-size: 12px;
            padding: 6px 8px;
            border: 1px solid rgba(0,0,0,.18);
            background: #fff;
