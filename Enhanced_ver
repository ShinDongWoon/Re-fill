// ==UserScript==
// @name         Re:fill - The Economist (Keynes) Robust
// @namespace    http://tampermonkey.net/
// @version      2.1.1
// @description  Robust Economist article chatbot: Readability extraction + SPA-safe + dock/floating UI + lightweight host-removal observer + role-safe Gemini payload. (fix recursion bug)
// @author       Dongwoon Shin
// @match        https://www.economist.com/*
// @match        https://www.wsj.com/*
// @match        https://www.ft.com/*
// @match        https://www.nytimes.com/*
// @connect      generativelanguage.googleapis.com
// @grant        GM_xmlhttpRequest
// @grant        GM_getValue
// @grant        GM_setValue
// @grant        GM_deleteValue
// @grant        GM_registerMenuCommand
// @run-at       document-idle
// @require      https://cdnjs.cloudflare.com/ajax/libs/readability/0.6.0/Readability.js
// @require      https://cdnjs.cloudflare.com/ajax/libs/readability/0.6.0/Readability-readerable.js
// ==/UserScript==

(function () {
  'use strict';

  /********************************************************************
   * 0) Constants / Defaults
   ********************************************************************/
  const APP = {
    NAME: 'Re:fill Keynes',
    VERSION: '2.1.1',
    HOST_ID: 'refill-keynes-host',
    STORAGE_PREFIX: 'refillKeynes.',
    GEMINI_MODEL: 'gemini-3-flash-preview',
    GEMINI_ENDPOINT: 'https://generativelanguage.googleapis.com/v1beta/models/',
    DEBUG: false,
  };

  const DEFAULTS = {
    // UI
    topOffsetPx: 80,
    bottomMarginPx: 16,
    floatRightPx: 16,
    floatWidthPx: 380,
    maxHeightPx: 850,
    dockMode: true,
    hideDockTargetIfAd: true,
    minimized: false,

    // Extraction / Prompt
    minUsefulChars: 1200,
    maxContextChars: 14000,
    ragTopK: 10,
    ragWindow: 1,
    includeHeadTailParas: 2,
    maxHistoryMessages: 8, // counts messages (user/model), not turns

    // Generation
    temperature: 0.2,
    maxOutputTokens: 2000,

    // Network
    requestTimeoutMs: 120000,
  };

  const SELECTORS = {
    DOCK_CANDIDATES: [
      '[data-test-id="right-hand-rail-ads"]',
      '[data-test-id*="right-hand-rail" i]',
      '[data-test-id*="rail" i]',
      'aside[role="complementary"]',
      '[role="complementary"]',
      'aside',
    ],
  };

  const STATE = {
    ui: null,                      // { host, shadow, el }
    dockTarget: null,
    dockTargetResizeObs: null,

    hostRemovalObs: null,
    hostRemovalObsTarget: null,
    reinitPending: false,

    pageKey: '',
    extractRetryTimer: null,
    extractAttempts: 0,

    article: {
      url: '',
      title: '',
      excerpt: '',
      text: '',
      paragraphs: [],
      source: 'none',
      extractedAt: 0,
      fingerprint: '',
    },

    history: [],                   // [{role:'user'|'model', text:string}]
    inFlight: false,
    requestSeq: 0,
  };

  /********************************************************************
   * 1) Small utilities
   ********************************************************************/
  function sKey(key) {
    return `${APP.STORAGE_PREFIX}${key}`;
  }
  function getSetting(key) {
    return GM_getValue(sKey(key), DEFAULTS[key]);
  }
  function setSetting(key, value) {
    GM_setValue(sKey(key), value);
  }
  function delSetting(key) {
    GM_deleteValue(sKey(key));
  }
  function log(...args) {
    if (APP.DEBUG) console.log(`[${APP.NAME}]`, ...args);
  }
  function normalizeUrl(u) {
    try {
      const url = new URL(u);
      url.hash = '';
      return url.toString();
    } catch {
      return u || '';
    }
  }
  function safeText(s) {
    return (s ?? '').toString();
  }
  function cleanText(text) {
    let t = safeText(text);
    t = t.replace(/\r/g, '');
    t = t.replace(/^\s*(Advertisement|광고)\s*$/gmi, '');
    t = t.replace(/[ \t]+\n/g, '\n');
    t = t.replace(/\n{3,}/g, '\n\n');
    return t.trim();
  }
  function splitParagraphs(text) {
    const t = cleanText(text);
    if (!t) return [];
    let paras = t.split(/\n{2,}/).map(p => p.trim()).filter(Boolean);
    if (paras.length >= 5) return paras;
    paras = t.split(/\n+/).map(p => p.trim()).filter(p => p.length >= 40);
    return paras;
  }
  function hashString32(str) {
    const s = safeText(str);
    let h = 2166136261;
    for (let i = 0; i < s.length; i++) {
      h ^= s.charCodeAt(i);
      h = Math.imul(h, 16777619);
    }
    return (h >>> 0).toString(16);
  }
  function clamp(n, a, b) {
    return Math.max(a, Math.min(b, n));
  }
  function debounce(fn, ms) {
    let t = null;
    return (...args) => {
      if (t) clearTimeout(t);
      t = setTimeout(() => fn(...args), ms);
    };
  }
  function requestIdle(cb, timeoutMs = 900) {
    if ('requestIdleCallback' in window) {
      return window.requestIdleCallback(cb, { timeout: timeoutMs });
    }
    return setTimeout(() => cb({ didTimeout: true, timeRemaining: () => 0 }), 0);
  }

  /********************************************************************
   * 2) Page eligibility (heavy-ish) — do NOT call from MutationObserver
   ********************************************************************/
  function extractFromJsonLd() {
    const scripts = Array.from(document.querySelectorAll('script[type="application/ld+json"]'));
    for (const s of scripts) {
      const raw = s.textContent;
      if (!raw) continue;
      try {
        const data = JSON.parse(raw);
        const arr = Array.isArray(data) ? data : [data];
        for (const obj of arr) {
          const type = obj?.['@type'];
          const types = Array.isArray(type) ? type : [type];
          const isArticle = types.includes('NewsArticle') || types.includes('Article') || types.includes('Report');
          if (!isArticle) continue;

          const title = obj.headline || obj.name || '';
          const excerpt = obj.description || '';
          const body = obj.articleBody || '';

          return {
            title: safeText(title),
            excerpt: safeText(excerpt),
            body: safeText(body),
            datePublished: safeText(obj.datePublished || obj.dateCreated || ''),
          };
        }
      } catch {}
    }
    return null;
  }

  function looksLikeArticlePage() {
    try {
      if (typeof isProbablyReaderable === 'function') {
        if (isProbablyReaderable(document, { minContentLength: 800 })) return true;
      }
    } catch {}

    const j = extractFromJsonLd();
    if (j && (j.body || j.title)) return true;

    const pCount = document.querySelectorAll('main p, article p').length;
    if (pCount >= 8) return true;

    return false;
  }

  /********************************************************************
   * 3) UI (Shadow DOM)
   ********************************************************************/
  function applyMinimizeStateUnsafe(ui) {
    // ✅ IMPORTANT: 이 함수는 절대로 ensureUI()를 호출하면 안 됨 (재귀 방지)
    if (!ui) return;
    const minimized = !!getSetting('minimized');
    if (minimized) ui.el.root.classList.add('minimized');
    else ui.el.root.classList.remove('minimized');
  }

  function ensureUI() {
    let host = document.getElementById(APP.HOST_ID);
    const firstRun = !STATE.ui;

    if (!host) {
      host = document.createElement('div');
      host.id = APP.HOST_ID;
      host.style.position = 'fixed';
      host.style.zIndex = '2147483647';
      host.style.top = `${getSetting('topOffsetPx')}px`;
      host.style.right = `${getSetting('floatRightPx')}px`;
      host.style.width = `${getSetting('floatWidthPx')}px`;
      host.style.pointerEvents = 'auto';
      (document.body || document.documentElement).appendChild(host);
      STATE.reinitPending = false;
    }

    let shadow = host.shadowRoot;
    if (!shadow) shadow = host.attachShadow({ mode: 'open' });

    // querySelector로 통일(브라우저 호환 리스크 최소화)
    if (!shadow.querySelector('#rk-root')) {
      shadow.innerHTML = `
