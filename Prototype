// ==UserScript==
// @name         Re:fill - The Economist Demo (Position Adjusted)
// @namespace    http://tampermonkey.net/
// @version      1.6
// @description  Adjusts the vertical position of the fixed AI chat bot.
// @author       Dongwoon Shin
// @match        https://www.economist.com/*/*
// @connect      generativelanguage.googleapis.com
// @grant        GM_addStyle
// @grant        GM_xmlhttpRequest
// @run-at       document-idle
// ==/UserScript==

(function() {
    'use strict';

    const GEMINI_API_KEY = 'Your_API_KEY';
    const ARTICLE_CONTAINER_SELECTOR = 'article[data-test-id="Article"]';
    const SIDEBAR_CONTAINER_SELECTOR = 'div[data-test-id="right-hand-rail-ads"]';

    function initializeReFill() {
        console.log('Re:fill Demo: 초기화 시작 (v1.6 - Position Adjusted)...');
        const articleContainer = document.querySelector(ARTICLE_CONTAINER_SELECTOR);
        const sidebarContainer = document.querySelector(SIDEBAR_CONTAINER_SELECTOR);
        if (!articleContainer || !sidebarContainer) { return; }
        const rect = sidebarContainer.getBoundingClientRect();
        const sidebarPosition = {
            top: rect.top + window.scrollY,
            left: rect.left,
            width: rect.width,
            height: rect.height
        };
        sidebarContainer.style.display = 'none';
        const articleContext = articleContainer.textContent;
        injectFixedUI(articleContext, sidebarPosition);
    }

    // --- ★★★ 1. 위치 조정 로직 ★★★ ---
    function injectFixedUI(context, position) {
        const fixedContainer = document.createElement('div');
        fixedContainer.id = 'refill-fixed-container';
        fixedContainer.style.position = 'fixed';
        // 'top' 값을 20px에서 80px로 늘려 헤더 아래에 위치하도록 조정
        fixedContainer.style.top = '80px';
        fixedContainer.style.left = `${position.left}px`;
        fixedContainer.style.width = `${position.width}px`;

        const wrapper = document.createElement('div');
        wrapper.id = 'refill-wrapper';
        const header = document.createElement('h3');
        header.textContent = 'Keynes';
        const messageArea = document.createElement('div');
        messageArea.id = 'refill-message-area';
        messageArea.innerHTML = '<div class="refill-message refill-message-ai">안녕하세요! 현재 읽고 계신 기사에 대해 무엇이든 물어보세요.</div>';
        const inputArea = document.createElement('div');
        inputArea.id = 'refill-input-area';
        const textInput = document.createElement('input');
        textInput.type = 'text';
        textInput.placeholder = '기사에 대해 질문하기...';
        textInput.id = 'refill-input';
        const sendButton = document.createElement('button');
        sendButton.textContent = '전송';
        sendButton.id = 'refill-send-button';

        inputArea.append(textInput, sendButton);
        wrapper.append(header, messageArea, inputArea);
        fixedContainer.appendChild(wrapper);
        document.body.appendChild(fixedContainer);

        sendButton.addEventListener('click', () => handleSend(context));
        textInput.addEventListener('keydown', (e) => {
            if (e.key === 'Enter') handleSend(context);
        });
    }

    function handleSend(context) {
        if (GEMINI_API_KEY === 'YOUR_API_KEY_HERE') {
            alert('오류: 스크립트 상단에 당신의 Gemini API 키를 입력해주세요.');
            return;
        }
        const textInput = document.getElementById('refill-input');
        const messageArea = document.getElementById('refill-message-area');
        const userQuestion = textInput.value.trim();
        if (!userQuestion) return;
        const userMessageDiv = document.createElement('div');
        userMessageDiv.className = 'refill-message refill-message-user';
        userMessageDiv.textContent = userQuestion;
        messageArea.appendChild(userMessageDiv);
        textInput.value = '';
        messageArea.scrollTop = messageArea.scrollHeight;
        const thinkingMessageDiv = document.createElement('div');
        thinkingMessageDiv.className = 'refill-message refill-message-ai';
        thinkingMessageDiv.id = 'refill-thinking-message';
        thinkingMessageDiv.textContent = '생각 중...';
        messageArea.appendChild(thinkingMessageDiv);
        messageArea.scrollTop = messageArea.scrollHeight;

        GM_xmlhttpRequest({
            method: 'POST',
            url: `https://generativelanguage.googleapis.com/v1beta/models/gemini-2.5-flash:generateContent?key=${GEMINI_API_KEY}`,
            headers: {
                'Content-Type': 'application/json'
            },
            data: JSON.stringify({
                "contents": [{
                    "parts": [{
                        "text": `System Prompt:\nYou are "Keynes", a world-class Economist. Your primary function is to answer user questions based on the provided article context. Follow these rules meticulously:\n1. Your answer must be derived **as much as possible** from the information within the "Article Text". \n2. If the answer cannot be found in the article, you have to respond with: "말씀하신 질문은 기사 내용을 벗어납니다.외부 지식을 사용해 답변드리겠습니다." and then respond continously with external knowledge. \n3. Be concise and directly address the user's question. Answer in Korean.\n\nArticle Text:\n${context}\n\nUser's Question:\n${userQuestion}`
                    }]
                }]
            }),
            onload: function(response) {
                const thinkingMsg = document.getElementById('refill-thinking-message');
                try {
                    const result = JSON.parse(response.responseText);
                    // Gemini API 에러 응답 처리 로직 추가
                    if (result.error) {
                        console.error('Gemini API Error:', result.error.message);
                        thinkingMsg.textContent = `API 오류가 발생했습니다: ${result.error.message}`;
                        return;
                    }
                    const aiResponse = result.candidates[0].content.parts[0].text;
                    thinkingMsg.textContent = aiResponse;
                } catch (error) {
                    console.error('Re:fill Demo: API 응답 처리 오류', error);
                    thinkingMsg.textContent = '죄송합니다, 답변을 처리하는 중 오류가 발생했습니다.';
                }
                thinkingMsg.id = '';
            },
            onerror: function(error) {
                const thinkingMsg = document.getElementById('refill-thinking-message');
                console.error('Re:fill Demo: API 호출 오류', error);
                thinkingMsg.textContent = '죄송합니다, API를 호출하는 중 네트워크 오류가 발생했습니다.';
                thinkingMsg.id = '';
            }
        });
    }

    // --- ★★★ 2. 높이 값 재계산 ★★★ ---
    GM_addStyle(`
        #refill-wrapper {
            border: 1px solid #ccc;
            border-radius: 8px;
            /* (화면 전체 높이 - 상단여백 80px - 하단여백 20px) 만큼을 높이로 지정 */
            height: calc(100vh - 100px);
            max-height: 850px;
            display: flex;
            flex-direction: column;
            font-family: Arial, sans-serif;
            background-color: #f9f9f9;
        }
        #refill-wrapper h3 { padding: 10px 15px; margin: 0; background-color: #eee; border-bottom: 1px solid #ccc; font-size: 16px; border-radius: 8px 8px 0 0; }
        #refill-message-area { flex-grow: 1; padding: 10px; overflow-y: auto; display: flex; flex-direction: column; gap: 10px; }
        .refill-message { padding: 8px 12px; border-radius: 15px; max-width: 85%; line-height: 1.4; }
        .refill-message-ai { background-color: #e1e1e1; align-self: flex-start; border-bottom-left-radius: 2px; }
        .refill-message-user { background-color: #007bff; color: white; align-self: flex-end; border-bottom-right-radius: 2px; }
        #refill-input-area { border-top: 1px solid #ccc; display: flex; padding: 10px; }
        #refill-input { flex-grow: 1; border: 1px solid #ccc; border-radius: 5px; padding: 8px; font-size: 14px; }
        #refill-send-button { margin-left: 10px; padding: 8px 15px; border: none; background-color: #007bff; color: white; border-radius: 5px; cursor: pointer; }
        #refill-send-button:hover { background-color: #0056b3; }
    `);

    setTimeout(initializeReFill, 1500);

})();
