// ==UserScript==
// @name         Re:fill - The Economist Demo
// @namespace    http://tampermonkey.net/
// @version      1.3
// @description  Injects a contextual AI chat bot into the ad whitespace on The Economist articles.
// @author       Dongwoon Shin
// @match        https://www.economist.com/*/*
// @connect      generativelanguage.googleapis.com
// @grant        GM_addStyle
// @grant        GM_xmlhttpRequest
// @run-at       document-idle
// ==/UserScript==

(function() {
    'use strict';

    // --- ★★★ 1. 구성(Configuration) ★★★ ---

    // Google AI Studio에서 발급받은 당신의 API 키를 여기에 붙여넣으세요.
    const GEMINI_API_KEY = 'YOUR_API_KEY_HERE';

    // 사용할 Gemini 모델을 지정합니다.
    const MODEL_NAME = 'gemini-2.5-flash';

    // 새로운 시스템 프롬프트 (AI의 역할 정의)
    const SYSTEM_PROMPT = "You are a rigorous economist analyzing an article from The Economist. Answer the user's questions about the provided text with precision and an analytical tone. Your answers must be strictly based on the article's content. All responses must be in Korean.";

    // --- 전역 변수 ---
    const ARTICLE_CONTAINER_SELECTOR = 'div.css-5nzj3w.ei2yr3n1';
    const AD_CONTAINER_SELECTOR = 'div.adComponent_right__A3uJw';
    let conversationHistory = []; // 대화 기록을 저장할 배열

    // --- 핵심 로직 ---
    function initializeReFill() {
        console.log('Re:fill Demo: 초기화 시작 (v1.3)...');
        const articleContainer = document.querySelector(ARTICLE_CONTAINER_SELECTOR);
        const adContainer = document.querySelector(AD_CONTAINER_SELECTOR);

        if (!articleContainer || !adContainer) {
            console.error('Re:fill Demo: 필수 요소를 찾을 수 없어 실행을 중단합니다.');
            return;
        }

        const articleContext = articleContainer.textContent;
        console.log('Re:fill Demo: 기사 컨텍스트 추출 완료.');
        injectUI(articleContext); // UI 주입 시 컨텍스트 전달
        console.log('Re:fill Demo: UI 주입 완료.');

        const observer = new MutationObserver((mutationsList, observer) => {
            for(const mutation of mutationsList) {
                if (mutation.type === 'attributes' && mutation.attributeName === 'class') {
                    const targetElement = mutation.target;
                    if (targetElement.classList.contains('adComponent_hidden__Dp0GM')) {
                        targetElement.classList.remove('adComponent_hidden__Dp0GM');
                    }
                }
            }
        });
        observer.observe(adContainer, { attributes: true });
        console.log('Re:fill Demo: 광고 컨테이너에 대한 감시를 시작합니다.');
    }

    function injectUI(context) {
        const targetElement = document.querySelector(AD_CONTAINER_SELECTOR);
        targetElement.innerHTML = '';
        targetElement.style.padding = '10px';
        const wrapper = document.createElement('div');
        wrapper.id = 'refill-wrapper';
        // ... (UI 생성 코드는 이전과 거의 동일)
        const header = document.createElement('h3');
        header.textContent = 'Re:fill AI Economist';
        const messageArea = document.createElement('div');
        messageArea.id = 'refill-message-area';
        messageArea.innerHTML = '<div class="refill-message refill-message-ai">The Economist 기사에 대해 무엇이든 질문하십시오. 경제학자의 관점에서 답변해 드리겠습니다.</div>';
        const inputArea = document.createElement('div');
        inputArea.id = 'refill-input-area';
        const textInput = document.createElement('input');
        textInput.type = 'text';
        textInput.placeholder = '기사에 대해 질문하기...';
        textInput.id = 'refill-input';
        const sendButton = document.createElement('button');
        sendButton.textContent = '전송';
        sendButton.id = 'refill-send-button';
        inputArea.append(textInput, sendButton);
        wrapper.append(header, messageArea, inputArea);
        targetElement.append(wrapper);

        // 이벤트 리스너에서 컨텍스트와 함께 handleSend 호출
        sendButton.addEventListener('click', () => handleSend(context));
        textInput.addEventListener('keydown', (e) => {
            if (e.key === 'Enter') {
                handleSend(context);
            }
        });
    }

    // --- ★★★ 2. API 호출 로직 업데이트 ★★★ ---
    function handleSend(context) {
        if (GEMINI_API_KEY === 'YOUR_API_KEY_HERE') {
            alert('오류: 스크립트 상단에 당신의 Gemini API 키를 입력해주세요.');
            return;
        }
        const textInput = document.getElementById('refill-input');
        const userQuestion = textInput.value.trim();
        if (!userQuestion) return;

        // UI에 사용자 메시지 표시
        displayMessage(userQuestion, 'user');
        textInput.value = '';

        // "생각 중..." 메시지 표시
        const thinkingMessageId = `thinking-${Date.now()}`;
        displayMessage('분석 중...', 'ai', thinkingMessageId);

        // 이전 대화 기록에 현재 질문 추가
        const currentUserContent = {
            "role": "user",
            "parts": [{ "text": `Article Text:\n${context}\n\nUser's Question:\n${userQuestion}` }]
        };
        const requestContents = [...conversationHistory, currentUserContent];

        GM_xmlhttpRequest({
            method: 'POST',
            url: `https://generativelanguage.googleapis.com/v1beta/models/${MODEL_NAME}:generateContent?key=${GEMINI_API_KEY}`,
            headers: { 'Content-Type': 'application/json' },
            data: JSON.stringify({
                "system_instruction": {
                    "parts": [{ "text": SYSTEM_PROMPT }]
                },
                "contents": requestContents
            }),
            onload: function(response) {
                try {
                    const result = JSON.parse(response.responseText);
                    const aiResponse = result.candidates[0].content.parts[0].text;
                    updateMessage(thinkingMessageId, aiResponse); // "생각 중" 메시지를 실제 답변으로 교체

                    // 대화 기록에 사용자 질문과 AI 답변 모두 저장
                    conversationHistory.push(currentUserContent);
                    conversationHistory.push(result.candidates[0].content); // 모델의 전체 응답 content 객체 저장

                } catch (error) {
                    console.error('Re:fill Demo: API 응답 처리 오류', error, response.responseText);
                    updateMessage(thinkingMessageId, '죄송합니다, 답변을 처리하는 중 오류가 발생했습니다.');
                }
            },
            onerror: function(error) {
                console.error('Re:fill Demo: API 호출 오류', error);
                updateMessage(thinkingMessageId, '죄송합니다, API를 호출하는 중 네트워크 오류가 발생했습니다.');
            }
        });
    }

    // --- 메시지 표시/업데이트 헬퍼 함수 ---
    function displayMessage(text, role, id = null) {
        const messageArea = document.getElementById('refill-message-area');
        const messageDiv = document.createElement('div');
        messageDiv.className = `refill-message refill-message-${role}`;
        messageDiv.textContent = text;
        if (id) {
            messageDiv.id = id;
        }
        messageArea.appendChild(messageDiv);
        messageArea.scrollTop = messageArea.scrollHeight;
        return messageDiv;
    }

    function updateMessage(id, newText) {
        const messageDiv = document.getElementById(id);
        if (messageDiv) {
            messageDiv.textContent = newText;
            messageDiv.id = ''; // ID 제거
        }
    }

    // --- UI 스타일링 (이전과 동일) ---
    GM_addStyle(`
        #refill-wrapper { border: 1px solid #ccc; border-radius: 8px; height: 580px; display: flex; flex-direction: column; font-family: Arial, sans-serif; background-color: #f9f9f9; }
        #refill-wrapper h3 { padding: 10px 15px; margin: 0; background-color: #eee; border-bottom: 1px solid #ccc; font-size: 16px; border-radius: 8px 8px 0 0; }
        #refill-message-area { flex-grow: 1; padding: 10px; overflow-y: auto; display: flex; flex-direction: column; gap: 10px; }
        .refill-message { padding: 8px 12px; border-radius: 15px; max-width: 85%; line-height: 1.4; white-space: pre-wrap; }
        .refill-message-ai { background-color: #e1e1e1; align-self: flex-start; border-bottom-left-radius: 2px; }
        .refill-message-user { background-color: #007bff; color: white; align-self: flex-end; border-bottom-right-radius: 2px; }
        #refill-input-area { border-top: 1px solid #ccc; display: flex; padding: 10px; }
        #refill-input { flex-grow: 1; border: 1px solid #ccc; border-radius: 5px; padding: 8px; font-size: 14px; }
        #refill-send-button { margin-left: 10px; padding: 8px 15px; border: none; background-color: #007bff; color: white; border-radius: 5px; cursor: pointer; }
        #refill-send-button:hover { background-color: #0056b3; }
    `);

    // --- 실행 ---
    setTimeout(initializeReFill, 2000);

})();
